# Copy to `.env` in this directory (gitignored). Run Compose from repo root; see README.md.

# Server folder (policy/ + logs/): relative e.g. servers/crick or absolute path.
SERVER_DEPLOY_DIR=servers/crick
# Unique name per stack on this host.
COMPOSE_PROJECT_NAME=data-archival-crick

IMAGE_NAME=ghcr.io/your-org/data-archival
IMAGE_TAG=latest
# Optional: COMPOSE_DOCKER_PLATFORM=linux/amd64 — force prod arch on Apple Silicon (aliases default arm64 there).
# Local-only image name (no registry): set COMPOSE_PULL_POLICY=never so Compose does not try Docker Hub.

SERVER_NAME=crick
CLIENT_NAME=TBUSA

# Bind mounts: full absolute paths (Compose does not expand ~). Policy paths must stay under these roots.
SCRATCH_PATH=/tmp/wgbs
ARCHIVE_PATH=/tmp/wgbs_global2
