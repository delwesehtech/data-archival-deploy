# Copy to .env (gitignored). Compose from repo root; see README.md.

# Server: policy+logs folder (relative or absolute). Unique project name per host.
SERVER_DEPLOY_DIR=servers/crick
COMPOSE_PROJECT_NAME=data-archival-crick

IMAGE_NAME=delwesehadmin/data-archival
IMAGE_TAG=v1.08
# COMPOSE_DOCKER_PLATFORM=linux/amd64
# COMPOSE_PULL_POLICY=never

SERVER_NAME=crick
CLIENT_NAME=client-name

# Host paths (absolute; no ~). Must match policy paths. Scratch=cleanup_scratch; archive=cleanup+archival+UI.
SCRATCH_PATH=/wgbs/scratch
ARCHIVE_PATH=/wgbs_global2/crick

# AWS: archival + visibility containers load this file (env_file). Required for S3 uploads and for UI “Mark for restore”.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_DEFAULT_REGION=us-east-1
# AWS_PROFILE=

# Glacier restore tier (optional). Default is in code: Expedited for GLACIER-class objects; DEEP_ARCHIVE
# cannot use Expedited (AWS), so the fastest restore there is Standard. Override with RESTORE_TIER=Bulk etc.
# RESTORE_TIER=Bulk

# Mark for restore: max items per POST (default 50; server caps env values to 50; set lower if needed).
# RESTORE_QUEUE_MAX_ITEMS=50
# RESTORE_QUEUE_MAX_INCOMING_ITEMS=50
