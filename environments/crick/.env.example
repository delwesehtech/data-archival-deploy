# Container image (local tag e.g. data-archival:latest is fine if you built on this host)
IMAGE_NAME=ghcr.io/your-org/data-archival
IMAGE_TAG=latest

# Set PULL_IMAGE=1 in shell when deploying from a registry (and run docker login first).
# Leave unset for locally built images.

# Host identity shown in visibility UI
SERVER_NAME=crick

# Host paths mounted into the container (1:1 host → container)
# 1) Scratch — cleanup_scratch + archival source
LOCAL_SCRATCH_PATH=/tmp/wgbs
# 2) Archive drive — cleanup_archive_drive + archival destination (visibility shows as archive path)
ARCHIVE_DRIVE_PATH=/tmp/wgbs_global2/
